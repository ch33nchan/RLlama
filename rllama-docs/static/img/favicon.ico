<svg width="200" height="200" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Llama body -->
  <ellipse cx="100" cy="120" rx="40" ry="60" fill="#20B2AA" />
  
  <!-- Llama head -->
  <circle cx="100" cy="60" r="25" fill="#FFFFFF" />
  
  <!-- Llama ears -->
  <path d="M85 45 L75 20 L90 35 Z" fill="#FF7F50" />
  <path d="M115 45 L125 20 L110 35 Z" fill="#FF7F50" />
  
  <!-- Llama hair tuft -->
  <ellipse cx="100" cy="40" rx="15" ry="10" fill="#20B2AA" />
  
  <!-- Green sunglasses -->
  <rect x="75" y="55" width="50" height="15" rx="5" fill="#9ACD32" />
  
  <!-- Weights bar -->
  <rect x="40" y="130" width="120" height="5" fill="#333" />
  
  <!-- Weights -->
  <circle cx="45" cy="130" r="12" fill="#FF7F50" stroke="#20B2AA" stroke-width="3" />
  <circle cx="155" cy="130" r="12" fill="#FF7F50" stroke="#20B2AA" stroke-width="3" />
  
  <!-- Llama smile -->
  <path d="M90 70 Q100 80 110 70" fill="none" stroke="#333" stroke-width="2" />
</svg>
